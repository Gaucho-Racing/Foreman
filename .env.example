# Copy to .env and edit. docker-compose.yaml ignores this file and uses
# its own inline env block; .env is for running the binary directly.

ENV="DEV"
PORT="7011"

DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_NAME="foreman"
DATABASE_USER="postgres"
DATABASE_PASSWORD="password"

# Reaper sweep cadence: how often to look for expired leases.
FOREMAN_REAPER_INTERVAL_SEC="10"

# Default lease length when a claim doesn't specify one.
FOREMAN_DEFAULT_LEASE_SEC="60"
